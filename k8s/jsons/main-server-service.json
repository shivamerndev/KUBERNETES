{
  "kind": "Service",
  "apiVersion": "v1",
  "metadata": {
    "name": "main-server"
  },
  "spec": {
    "selector": {
      "app": "main-server"
    },
    "type": "ClusterIp",
    "ports": [
      {
        "name": "main-server",
        "port": 80,
        "targetPort": 3000
      }
    ]
  }
}